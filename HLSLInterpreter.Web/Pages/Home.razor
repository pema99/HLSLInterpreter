@page "/"
@inject IJSRuntime JS
@using HLSL
@using UnityShaderParser.HLSL
@using System.Globalization
@implements IAsyncDisposable

<div class="app-shell">
    <header class="topbar">
        <a class="logo" href="https://github.com/pema99/HLSLInterpreter" target="_blank" rel="noopener noreferrer">HLSL Interpreter</a>

        <div class="topbar-center">
            @if (isDebugging)
            {
                <div class="debug-controls">
                    <button class="btn-dbg btn-dbg-continue" @onclick="ContinueToBreakpoint" title="Continue to next breakpoint">&#x25B6;</button>
                    <button class="btn-dbg" @onclick="StepOver" disabled="@(debugStepIndex >= debugTrace.Count - 1)" title="Step over">&#x21B7;</button>
                    <button class="btn-dbg" @onclick="StepForward" disabled="@(debugStepIndex >= debugTrace.Count - 1)" title="Step in">&#x21A7;</button>
                    <button class="btn-dbg" @onclick="StepOut" disabled="@(debugStepIndex >= debugTrace.Count - 1)" title="Step out">&#x21A5;</button>
                    <button class="btn-dbg" @onclick="StepBack" disabled="@(debugStepIndex <= 0)" title="Step back">&#x23EE;</button>
                </div>
            }
        </div>

        <div class="topbar-right">
            @if (isDebugging)
            {
                <div class="thread-selector">
                    <label class="warp-label">Thread</label>
                    <input class="warp-input" type="number" min="0" max="@(warpX * warpY - 1)"
                           @bind="inspectedThread" @bind:event="oninput" />
                    <span class="warp-sep">(@(inspectedThread % warpX), @(inspectedThread / warpX))</span>
                </div>
            }
            <div class="warp-control">
                <label class="warp-label">Warp size</label>
                <input class="warp-input" type="number" min="1" max="32" @bind="warpX" @bind:event="oninput" disabled="@(isRunning || isDebugging)" title="Warp X" />
                <span class="warp-sep">×</span>
                <input class="warp-input" type="number" min="1" max="32" @bind="warpY" @bind:event="oninput" disabled="@(isRunning || isDebugging)" title="Warp Y" />
            </div>
            <button class="btn-run" @onclick="Run" disabled="@(isRunning || isDebugging)">
                @if (isRunning)
                {
                    <span class="spinner"></span>
                    <span>Running...</span>
                }
                else
                {
                    <span>&#9654; Run</span>
                }
            </button>
            @if (isDebugging)
            {
                <button class="btn-stop" @onclick="ExitDebug" title="Stop debugging">&#x25A0; Stop</button>
            }
            else
            {
                <button class="btn-debug-start" @onclick="StartDebug" disabled="@isRunning" title="Debug (record execution trace)">&#x1F41E; Debug</button>
            }
        </div>
    </header>

    <div class="main-split">
        <div class="editor-panel">
            <div class="panel-header">
                <span>Input</span>
                <select class="footer-select" title="Font size" @onchange="OnFontSizeChanged">
                    @foreach (var size in fontSizes)
                    {
                        <option value="@size" selected="@(size == fontSize)">@size</option>
                    }
                </select>
            </div>
            <div id="monaco-container" class="editor-container"></div>
        </div>

        <div class="resize-h-handle" title="Drag to resize"></div>

        @{
            var _dbgStep = (isDebugging && debugStepIndex >= 0 && debugStepIndex < debugTrace.Count)
                ? debugTrace[debugStepIndex] : null;
            var _frameIdx = _dbgStep != null
                ? Math.Clamp(selectedFrame, 0, Math.Max(0, _dbgStep.FrameThreadStates.Length - 1)) : 0;
            var threadStates = (_dbgStep != null && _frameIdx < _dbgStep.FrameThreadStates.Length)
                ? _dbgStep.FrameThreadStates[_frameIdx]
                : Array.Empty<HLSLExecutionState.ThreadState>();
        }
        <div class="output-panel">
            @if (isDebugging)
            {
                <!-- Variables -->
                <div class="debug-section debug-section-vars @(varsCollapsed ? "section-collapsed" : "")">
                    <div class="panel-header collapsible-header" @onclick="() => varsCollapsed = !varsCollapsed">
                        <div class="panel-header-left">
                            <span class="collapse-icon @(varsCollapsed ? "" : "expanded")">&#x203A;</span>
                            <span>Variables</span>
                        </div>
                    </div>
                    @if (!varsCollapsed)
                    {
                        <div class="output-body debug-vars-body">
                            @if (debugStepIndex >= 0 && debugStepIndex < debugTrace.Count)
                            {
                                var step = debugTrace[debugStepIndex];
                                var localFrameIdx = Math.Clamp(selectedFrame, 0, Math.Max(0, step.FrameVariables.Length - 1));
                                var locals = localFrameIdx < step.FrameVariables.Length ? step.FrameVariables[localFrameIdx] : null;
                                var globals = step.GlobalVariables;

                                bool hasLocals = locals != null && locals.Count > 0;
                                bool hasGlobals = globals != null && globals.Count > 0;

                                if (!hasLocals && !hasGlobals)
                                {
                                    <div class="hint">No variables in scope.</div>
                                }
                                else
                                {
                                    <div class="var-list">
                                        @{
                                            var rows = new List<VarRow>();
                                            if (hasLocals)
                                                foreach (var kvp in locals!)
                                                    BuildVarRows(rows, kvp.Key, kvp.Value, 0, kvp.Key);
                                            var globalRows = new List<VarRow>();
                                            if (hasGlobals)
                                                foreach (var kvp in globals!)
                                                    BuildVarRows(globalRows, kvp.Key, kvp.Value, 0, "g:" + kvp.Key);
                                        }
                                        @if (hasLocals)
                                        {
                                            <div class="var-subsection-header" @onclick="() => localVarsCollapsed = !localVarsCollapsed">
                                                <span class="collapse-icon @(localVarsCollapsed ? "" : "expanded")">&#x203A;</span>
                                                <span>Locals</span>
                                            </div>
                                            if (!localVarsCollapsed)
                                            {
                                                foreach (var row in rows)
                                                {
                                                    var rowPath = row.Path;
                                                    <div class="var-row" style="padding-left: @(6 + row.Depth * 18)px">
                                                        @if (row.IsExpandable)
                                                        {
                                                            <span class="var-toggle @(expandedVarPaths.Contains(rowPath) ? "expanded" : "")"
                                                                  @onclick="() => ToggleVarPath(rowPath)">&#x25BA;</span>
                                                        }
                                                        else
                                                        {
                                                            <span class="var-toggle-spacer"></span>
                                                        }
                                                        <span class="var-row-name" title="@row.Name">@row.Name</span>
                                                        <span class="var-row-value">@FormatValue(row.Value, inspectedThread)</span>
                                                    </div>
                                                }
                                            }
                                        }
                                        @if (hasGlobals)
                                        {
                                            <div class="var-subsection-header" @onclick="() => globalVarsCollapsed = !globalVarsCollapsed">
                                                <span class="collapse-icon @(globalVarsCollapsed ? "" : "expanded")">&#x203A;</span>
                                                <span>Globals</span>
                                            </div>
                                            if (!globalVarsCollapsed)
                                            {
                                                foreach (var row in globalRows)
                                                {
                                                    var rowPath = row.Path;
                                                    <div class="var-row" style="padding-left: @(6 + row.Depth * 18)px">
                                                        @if (row.IsExpandable)
                                                        {
                                                            <span class="var-toggle @(expandedVarPaths.Contains(rowPath) ? "expanded" : "")"
                                                                  @onclick="() => ToggleVarPath(rowPath)">&#x25BA;</span>
                                                        }
                                                        else
                                                        {
                                                            <span class="var-toggle-spacer"></span>
                                                        }
                                                        <span class="var-row-name" title="@row.Name">@row.Name</span>
                                                        <span class="var-row-value">@FormatValue(row.Value, inspectedThread)</span>
                                                    </div>
                                                }
                                            }
                                        }
                                    </div>
                                }
                            }
                            else
                            {
                                <div class="hint">Use Step or Continue to inspect variables.</div>
                            }
                        </div>
                        <div class="resize-v-handle" title="Drag to resize"></div>
                    }
                </div>

                <!-- Call Stack + Execution State -->
                <div class="debug-section debug-section-callstack @(callStackCollapsed ? "section-collapsed" : "")">
                    <div class="panel-header collapsible-header" @onclick="() => { callStackCollapsed = !callStackCollapsed; if (!callStackCollapsed) needsThreadGridInit = true; }">
                        <div class="panel-header-left">
                            <span class="collapse-icon @(callStackCollapsed ? "" : "expanded")">&#x203A;</span>
                            <span>Call Stack</span>
                        </div>
                        @if (!callStackCollapsed && threadStates.Length > 0)
                        {
                            <span class="thread-legend">
                                <span class="tl-dot tc-active"></span>Active thread
                                <span class="tl-dot tc-diverged"></span>Inactive thread
                            </span>
                        }
                    </div>
                    @if (!callStackCollapsed)
                    {
                        <div class="callstack-exec-body">
                            <div class="callstack-pane">
                                @if (debugStepIndex >= 0 && debugStepIndex < debugTrace.Count)
                                {
                                    var stack = debugTrace[debugStepIndex].CallStack;
                                    <table class="var-table">
                                        <tbody>
                                            @for (int i = 0; i < stack.Length; i++)
                                            {
                                                var fi = i;
                                                <tr class="@(fi == selectedFrame ? "callstack-selected" : "")"
                                                    @onclick="() => selectedFrame = fi"
                                                    style="cursor: pointer;">
                                                    <td class="var-name">@stack[i]</td>
                                                </tr>
                                            }
                                            <tr style="cursor: default;">
                                                <td class="var-name" style="color: #555; font-style: italic;">[Globals]</td>
                                            </tr>
                                        </tbody>
                                    </table>
                                }
                                else
                                {
                                    <div class="hint">Use Step or Continue to inspect call stack.</div>
                                }
                            </div>
                            @if (threadStates.Length > 0)
                            {
                                <div class="resize-inner-h-handle" id="callstack-exec-divider"></div>
                                <div class="exec-state-body" id="thread-grid-container">
                                    <div class="thread-grid">
                                        @for (int ti = 0; ti < threadStates.Length; ti++)
                                        {
                                            var tidx = ti;
                                            var state = threadStates[ti];
                                            var stateClass = state switch {
                                                HLSLExecutionState.ThreadState.Active    => "tc-active",
                                                HLSLExecutionState.ThreadState.Inactive  => "tc-diverged",
                                                HLSLExecutionState.ThreadState.Suspended => "tc-suspended",
                                                _ => ""
                                            };
                                            var label = $"Thread ({ti % warpX}, {ti / warpX}) – {state}";
                                            <div class="thread-cell @stateClass @(tidx == inspectedThread ? "tc-selected" : "")"
                                                 title="@label"
                                                 @onclick="() => inspectedThread = tidx"></div>
                                        }
                                    </div>
                                </div>
                            }
                        </div>
                        <div class="resize-v-handle" title="Drag to resize"></div>
                    }
                </div>

                <!-- Immediate -->
                <div class="debug-section debug-section-immediate @(immediateCollapsed ? "section-collapsed" : "")">
                    <div class="panel-header collapsible-header" @onclick="() => immediateCollapsed = !immediateCollapsed">
                        <div class="panel-header-left">
                            <span class="collapse-icon @(immediateCollapsed ? "" : "expanded")">&#x203A;</span>
                            <span>Immediate</span>
                        </div>
                    </div>
                    @if (!immediateCollapsed)
                    {
                        <div class="output-body imm-body">
                            @if (immediateHistory.Count == 0)
                            {
                                <div class="hint">Evaluate expressions in the current scope.</div>
                            }
                            else
                            {
                                <div class="imm-history">
                                    @foreach (var entry in immediateHistory)
                                    {
                                        <div class="imm-entry">
                                            <div class="imm-expr"><span class="imm-prompt">&gt;</span> @entry.Expression</div>
                                            <div class="imm-result @(entry.IsError ? "imm-error" : "")">@entry.Result</div>
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                        <div class="imm-input-row">
                            <span class="imm-prompt-inline">&gt;</span>
                            <input class="imm-input" type="text" placeholder="Expression..."
                                   @bind="immediateInput" @bind:event="oninput"
                                   @onkeydown="OnImmediateKeyDown" />
                            <button class="imm-eval-btn" @onclick="EvaluateImmediate" disabled="@(debugStepIndex < 0)">Eval</button>
                        </div>
                        <div class="resize-v-handle" title="Drag to resize"></div>
                    }
                </div>

                <!-- Console Output -->
                <div class="debug-section debug-section-console @(consoleCollapsed ? "section-collapsed" : "")">
                    <div class="panel-header collapsible-header" @onclick="() => consoleCollapsed = !consoleCollapsed">
                        <div class="panel-header-left">
                            <span class="collapse-icon @(consoleCollapsed ? "" : "expanded")">&#x203A;</span>
                            <span>Console</span>
                        </div>
                    </div>
                    @if (!consoleCollapsed)
                    {
                        <div class="output-body debug-console-body">
                            @if (!string.IsNullOrEmpty(CurrentDebugOutput))
                            {
                                <pre class="output-text">@CurrentDebugOutput</pre>
                            }
                            else
                            {
                                <div class="hint">No output yet.</div>
                            }
                            @if (hasError)
                            {
                                <pre class="error-text">@errorMessage</pre>
                            }
                        </div>
                        <div class="resize-v-handle" title="Drag to resize"></div>
                    }
                </div>

                <!-- Color Output -->
                @if (hasImage)
                {
                    <div class="debug-section debug-section-image @(imageCollapsed ? "section-collapsed" : "")">
                        <div class="panel-header collapsible-header" @onclick="ToggleImageSection">
                            <div class="panel-header-left">
                                <span class="collapse-icon @(imageCollapsed ? "" : "expanded")">&#x203A;</span>
                                <span>Color Output</span>
                            </div>
                        </div>
                        @if (!imageCollapsed)
                        {
                            <div class="image-container">
                                <canvas id="color-canvas"></canvas>
                            </div>
                            <div class="resize-v-handle" title="Drag to resize"></div>
                        }
                    </div>
                }

                <div class="debug-panel-spacer"></div>
            }
            else
            {
                <!-- Console -->
                <div class="debug-section debug-section-console @(consoleCollapsed ? "section-collapsed" : "")"
                     style="--section-h: 200px;">
                    <div class="panel-header collapsible-header" @onclick="() => consoleCollapsed = !consoleCollapsed">
                        <div class="panel-header-left">
                            <span class="collapse-icon @(consoleCollapsed ? "" : "expanded")">&#x203A;</span>
                            <span>Console</span>
                        </div>
                    </div>
                    @if (!consoleCollapsed)
                    {
                        <div class="output-body">
                            @if (output == null && !isRunning)
                            {
                                <div class="hint">Press <strong>Run</strong> or <strong>Ctrl+Enter</strong> to execute.</div>
                            }
                            else if (isRunning)
                            {
                                <div class="hint running-hint"><span class="spinner spinner-output"></span> Running...</div>
                            }
                            else if (output!.Length == 0 && !hasError)
                            {
                                <div class="hint">No output.</div>
                            }
                            else
                            {
                                @if (!string.IsNullOrEmpty(output))
                                {
                                    <pre class="output-text">@output</pre>
                                }
                                @if (hasError)
                                {
                                    <pre class="error-text">@errorMessage</pre>
                                }
                            }
                        </div>
                        <div class="resize-v-handle" title="Drag to resize"></div>
                    }
                </div>

                <!-- Color Output -->
                @if (hasImage)
                {
                    <div class="debug-section debug-section-image @(imageCollapsed ? "section-collapsed" : "")">
                        <div class="panel-header collapsible-header" @onclick="ToggleImageSection">
                            <div class="panel-header-left">
                                <span class="collapse-icon @(imageCollapsed ? "" : "expanded")">&#x203A;</span>
                                <span>Color Output</span>
                            </div>
                        </div>
                        @if (!imageCollapsed)
                        {
                            <div class="image-container">
                                <canvas id="color-canvas"></canvas>
                            </div>
                            <div class="resize-v-handle" title="Drag to resize"></div>
                        }
                    </div>
                }

                <div class="debug-panel-spacer"></div>
            }
        </div>
    </div>
</div>

@code {
    private static readonly string DefaultCode =
@"float4 main(uint2 thread : SV_DispatchThreadID)
{
    // Calculate UV coord
    float2 resolution = float2(WARP_SIZE_X - 1, WARP_SIZE_Y - 1);
    float2 uv = float2(thread) / resolution;

    // Debug a specific pixel
    if (thread.x == 1 && thread.y <= 1)
        PRINTF(""Thread (%d, %d) value: %d"", thread.x, thread.y, uv);

    // Output some color
    return float4(uv.x, uv.y, 0.5, 1.0);
}
";

    private static readonly int[] fontSizes = { 12, 13, 14, 15, 16, 18, 20, 22, 24, 26, 28, 30, 32, 34, 36 };
    private int fontSize = 16;

    private async Task OnFontSizeChanged(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out int size))
        {
            fontSize = size;
            await JS.InvokeVoidAsync("setMonacoFontSize", size);
        }
    }

    // --- Core state ---
    private HLSLRunner runner = new HLSLRunner();
    private string? output;
    private bool isRunning;
    private bool hasError;
    private string errorMessage = "";
    private int warpX = 8;
    private int warpY = 8;
    private bool hasImage = false;
    private bool needsImageRender = false;
    private int imageWidth, imageHeight;
    private byte[]? imagePixels;

    // --- Debug state ---
    private bool isDebugging = false;
    private List<DebugStep> debugTrace = new();
    private int debugStepIndex = -1;
    private HashSet<int> breakpoints = new();
    private int _inspectedThread = 0;
    private DotNetObjectReference<Home>? dotNetRef;
    private bool needsThreadGridInit = false;
    private bool needsSectionHeightRestore = false;
    private string debugCode = "";

    // --- Collapse state ---
    private int selectedFrame = 0;
    private HashSet<string> expandedVarPaths = new();
    private bool varsCollapsed = false;
    private bool localVarsCollapsed = false;
    private bool globalVarsCollapsed = false;
    private bool callStackCollapsed = false;
    private bool imageCollapsed = false;
    private bool consoleCollapsed = false;
    private bool immediateCollapsed = false;

    // --- Immediate window ---
    private string immediateInput = "";
    private List<ImmediateEntry> immediateHistory = new();

    private sealed class ImmediateEntry
    {
        public string Expression { get; init; } = "";
        public string Result { get; init; } = "";
        public bool IsError { get; init; }
    }

    private int inspectedThread
    {
        get => _inspectedThread;
        set => _inspectedThread = Math.Clamp(value, 0, Math.Max(0, warpX * warpY - 1));
    }

    private int currentDebugLine =>
        (debugStepIndex >= 0 && debugStepIndex < debugTrace.Count)
            ? debugTrace[debugStepIndex].Line : 0;

    private sealed class DebugStep
    {
        public int Line { get; init; }
        public string[] CallStack { get; init; } = Array.Empty<string>();
        public int CallDepth => CallStack.Length;
        // Per-frame local variables, index 0 = innermost (current) frame
        public Dictionary<string, HLSLValue>[] FrameVariables { get; init; } = Array.Empty<Dictionary<string, HLSLValue>>();
        public Dictionary<string, HLSLValue> GlobalVariables { get; init; } = new();
        public int OutputOffset { get; init; }
        public HLSLExecutionState.ThreadState[][] FrameThreadStates { get; init; } = Array.Empty<HLSLExecutionState.ThreadState[]>();
    }

    // Console output visible at the current debug step (output produced by statements executed so far).
    private string CurrentDebugOutput
    {
        get
        {
            if (output == null || debugStepIndex < 0) return "";
            // Output produced *through* step N ends at the start of step N+1's offset (or total length if last).
            int endOffset = debugStepIndex < debugTrace.Count - 1
                ? debugTrace[debugStepIndex + 1].OutputOffset
                : output.Length;
            return output[..Math.Min(endOffset, output.Length)];
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            dotNetRef = DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync("initMonaco", "monaco-container", DefaultCode, dotNetRef);
        }

        if (needsSectionHeightRestore)
        {
            needsSectionHeightRestore = false;
            await JS.InvokeVoidAsync("restoreSectionHeights");
        }

        if (needsImageRender && imagePixels != null)
        {
            needsImageRender = false;
            await JS.InvokeVoidAsync("restoreImageSectionHeight");
            await JS.InvokeVoidAsync("renderPixels", "color-canvas", imagePixels, imageWidth, imageHeight);
        }

        if (needsThreadGridInit)
        {
            needsThreadGridInit = false;
            await JS.InvokeVoidAsync("initThreadGridResize", "thread-grid-container", warpX, warpY);
        }
    }

    // --- Run (normal mode) ---
    private async Task Run()
    {
        isRunning = true;
        hasError = false;
        errorMessage = "";
        output = null;
        hasImage = false;
        imagePixels = null;
        StateHasChanged();
        await Task.Yield();

        var sw = new System.IO.StringWriter();
        var oldOut = Console.Out;
        Console.SetOut(sw);

        try
        {
            string code = await JS.InvokeAsync<string>("getMonacoValue");
            int wx = Math.Max(1, warpX);
            int wy = Math.Max(1, warpY);
            int threadCount = wx * wy;

            runner.DebugHook = null;
            runner.Reset();
            runner.SetWarpSize(wx, wy);
            runner.SetVariable("WARP_SIZE_X", new ScalarValue(ScalarType.Uint, new HLSLRegister<object>((uint)wx)));
            runner.SetVariable("WARP_SIZE_Y", new ScalarValue(ScalarType.Uint, new HLSLRegister<object>((uint)wy)));
            runner.ProcessCode(code);

            var threadArg = BuildThreadArg(wx, wy, threadCount);
            HLSLValue result = CallMain(threadArg);
            TryExtractImage(result, wx, wy);
        }
        catch (Exception ex)
        {
            hasError = true;
            errorMessage = ex.Message;
        }
        finally
        {
            Console.SetOut(oldOut);
        }

        output = sw.ToString();
        needsImageRender = hasImage;
        isRunning = false;
        StateHasChanged();
    }

    // --- Debug: record trace ---
    private async Task StartDebug()
    {
        isRunning = true;
        hasError = false;
        errorMessage = "";
        output = null;
        hasImage = false;
        imagePixels = null;
        debugTrace = new();
        debugStepIndex = -1;
        immediateCollapsed = false;
        consoleCollapsed = true;
        imageCollapsed = true;
        await JS.InvokeVoidAsync("saveSectionHeights");
        StateHasChanged();
        await Task.Yield();

        var sw = new System.IO.StringWriter();
        var oldOut = Console.Out;
        Console.SetOut(sw);

        try
        {
            string code = await JS.InvokeAsync<string>("getMonacoValue");
            debugCode = code;
            immediateHistory = new();
            int wx = Math.Max(1, warpX);
            int wy = Math.Max(1, warpY);
            int threadCount = wx * wy;

            runner.Reset();
            runner.SetWarpSize(wx, wy);
            runner.SetVariable("WARP_SIZE_X", new ScalarValue(ScalarType.Uint, new HLSLRegister<object>((uint)wx)));
            runner.SetVariable("WARP_SIZE_Y", new ScalarValue(ScalarType.Uint, new HLSLRegister<object>((uint)wy)));

            runner.DebugHook = node =>
            {
                Dictionary<string, HLSLValue> CopyFrame(Dictionary<string, HLSLValue> frame)
                {
                    var copy = new Dictionary<string, HLSLValue>();
                    foreach (var kvp in frame)
                    {
                        HLSLValue val = kvp.Value is ReferenceValue rv ? rv.Get() : kvp.Value;
                        try { copy[kvp.Key] = val?.Copy() ?? val!; }
                        catch { copy[kvp.Key] = val!; }
                    }
                    return copy;
                }

                var frameCopies = runner.GetVariablesPerFrame().Select(CopyFrame).ToArray();
                var globalCopy = CopyFrame(runner.GetGlobalVariables());

                debugTrace.Add(new DebugStep
                {
                    Line = node.Span.Start.Line,
                    CallStack = runner.GetCallStack(),
                    FrameVariables = frameCopies,
                    GlobalVariables = globalCopy,
                    OutputOffset = sw.GetStringBuilder().Length,
                    FrameThreadStates = runner.GetThreadStatesPerFrame()
                });
            };

            runner.ProcessCode(code);
            var threadArg = BuildThreadArg(wx, wy, threadCount);
            HLSLValue result = CallMain(threadArg);
            TryExtractImage(result, wx, wy);
        }
        catch (Exception ex)
        {
            hasError = true;
            errorMessage = ex.Message;
        }
        finally
        {
            runner.DebugHook = null;
            Console.SetOut(oldOut);
        }

        output = sw.ToString();
        needsImageRender = hasImage;
        isRunning = false;
        isDebugging = true;

        // Position at first step
        if (debugTrace.Count > 0)
        {
            debugStepIndex = 0;
            await JS.InvokeVoidAsync("highlightDebugLine", currentDebugLine);
        }

        needsSectionHeightRestore = true;
        needsThreadGridInit = true;
        StateHasChanged();
    }

    // --- Debug navigation ---
    private async Task StepForward()
    {
        if (debugStepIndex < debugTrace.Count - 1)
        {
            debugStepIndex++;
            selectedFrame = 0;
            await JS.InvokeVoidAsync("highlightDebugLine", currentDebugLine);
            StateHasChanged();
        }
    }

    private async Task StepBack()
    {
        if (debugStepIndex > 0)
        {
            debugStepIndex--;
            selectedFrame = 0;
            await JS.InvokeVoidAsync("highlightDebugLine", currentDebugLine);
            StateHasChanged();
        }
    }

    private async Task StepOver()
    {
        if (debugStepIndex >= debugTrace.Count - 1) return;
        int depth = debugTrace[debugStepIndex].CallDepth;
        int next = debugStepIndex + 1;
        while (next < debugTrace.Count - 1 && debugTrace[next].CallDepth > depth)
            next++;
        debugStepIndex = next;
        selectedFrame = 0;
        await JS.InvokeVoidAsync("highlightDebugLine", currentDebugLine);
        StateHasChanged();
    }

    private async Task StepOut()
    {
        if (debugStepIndex >= debugTrace.Count - 1) return;
        int depth = debugTrace[debugStepIndex].CallDepth;
        int next = debugStepIndex + 1;
        while (next < debugTrace.Count - 1 && debugTrace[next].CallDepth >= depth)
            next++;
        debugStepIndex = next;
        selectedFrame = 0;
        await JS.InvokeVoidAsync("highlightDebugLine", currentDebugLine);
        StateHasChanged();
    }

    private async Task ContinueToBreakpoint()
    {
        int next = debugStepIndex + 1;
        while (next < debugTrace.Count && !breakpoints.Contains(debugTrace[next].Line))
            next++;
        debugStepIndex = Math.Min(next, debugTrace.Count - 1);
        selectedFrame = 0;
        await JS.InvokeVoidAsync("highlightDebugLine", currentDebugLine);
        StateHasChanged();
    }


    private void ToggleImageSection()
    {
        imageCollapsed = !imageCollapsed;
        if (!imageCollapsed && hasImage && imagePixels != null)
            needsImageRender = true;
    }

    private async Task ExitDebug()
    {
        await JS.InvokeVoidAsync("saveSectionHeights");
        isDebugging = false;
        debugTrace = new();
        debugStepIndex = -1;
        consoleCollapsed = false;
        imageCollapsed = false;
        await JS.InvokeVoidAsync("highlightDebugLine", 0);
        await JS.InvokeVoidAsync("disposeThreadGridResize");
        needsSectionHeightRestore = true;
        StateHasChanged();
    }

    [JSInvokable]
    public async Task ToggleBreakpoint(int line)
    {
        if (breakpoints.Contains(line))
            breakpoints.Remove(line);
        else
            breakpoints.Add(line);

        await JS.InvokeVoidAsync("setBreakpoints", breakpoints.ToArray());
        StateHasChanged();
    }

    // --- Value formatting ---
    // --- Hierarchical variable list ---
    private sealed class VarRow
    {
        public string Path = "";
        public string Name = "";
        public HLSLValue Value = null!;
        public int Depth;
        public bool IsExpandable;
    }

    private void ToggleVarPath(string path)
    {
        if (!expandedVarPaths.Remove(path))
            expandedVarPaths.Add(path);
    }

    private void BuildVarRows(List<VarRow> rows, string name, HLSLValue value, int depth, string path)
    {
        if (value is ReferenceValue rv) value = rv.Get();
        bool isExpandable = value is StructValue or ArrayValue;
        rows.Add(new VarRow { Path = path, Name = name, Value = value, Depth = depth, IsExpandable = isExpandable });

        if (!isExpandable || !expandedVarPaths.Contains(path)) return;

        if (value is StructValue sv)
        {
            foreach (var kvp in sv.Members)
                BuildVarRows(rows, kvp.Key, kvp.Value, depth + 1, $"{path}.{kvp.Key}");
        }
        else if (value is ArrayValue av)
        {
            for (int i = 0; i < av.Values.Length; i++)
                BuildVarRows(rows, $"[{i}]", av.Values[i], depth + 1, $"{path}[{i}]");
        }
    }

    private string FormatValue(HLSLValue value, int threadIndex)
    {
        if (value is ReferenceValue rv) value = rv.Get();
        if (value == null) return "null";

        return value switch
        {
            ScalarValue sv => FormatScalar(sv, threadIndex),
            VectorValue vv => FormatVector(vv, threadIndex),
            MatrixValue mv => FormatMatrix(mv, threadIndex),
            StructValue sv2 => FormatStruct(sv2, threadIndex),
            ArrayValue av => $"[{av.Values.Length}]",
            _ => value.GetType().Name
        };
    }

    private string FormatScalar(ScalarValue sv, int threadIndex)
    {
        try
        {
            int idx = Math.Min(threadIndex, sv.ThreadCount - 1);
            object v = sv.Value.Get(idx);
            return FormatObject(v);
        }
        catch { return "?"; }
    }

    private string FormatVector(VectorValue vv, int threadIndex)
    {
        try
        {
            int idx = Math.Min(threadIndex, vv.ThreadCount - 1);
            object[] comps = vv.Values.Get(idx);
            if (comps == null) return "(null)";
            return $"({string.Join(", ", comps.Select(c => FormatObject(c)))})";
        }
        catch { return "?"; }
    }

    private string FormatMatrix(MatrixValue mv, int threadIndex)
    {
        try
        {
            int idx = Math.Min(threadIndex, mv.ThreadCount - 1);
            object[] elems = mv.Values.Get(idx);
            if (elems == null) return "[null]";
            return $"[{mv.Rows}x{mv.Columns}: {string.Join(", ", elems.Take(4).Select(c => FormatObject(c)))}...]";
        }
        catch { return "[matrix]"; }
    }

    private string FormatStruct(StructValue sv, int threadIndex)
    {
        try
        {
            var parts = sv.Members.Take(4).Select(kv => $"{kv.Key}: {FormatValue(kv.Value, threadIndex)}");
            string body = string.Join(", ", parts);
            if (sv.Members.Count > 4) body += ", ...";
            return "{" + body + "}";
        }
        catch { return "{struct}"; }
    }

    private static string FormatObject(object? v)
    {
        if (v is float f) return f.ToString("G6", CultureInfo.InvariantCulture);
        if (v is double d) return d.ToString("G6", CultureInfo.InvariantCulture);
        return Convert.ToString(v, CultureInfo.InvariantCulture) ?? "null";
    }

    // --- Helpers shared by Run and StartDebug ---
    private static VectorValue BuildThreadArg(int wx, int wy, int threadCount)
    {
        var threadIds = new object[threadCount][];
        for (int i = 0; i < threadCount; i++)
            threadIds[i] = new object[] { (uint)(i % wx), (uint)(i / wx) };
        return new VectorValue(ScalarType.Uint, new HLSLRegister<object[]>(threadIds).Converge());
    }

    private HLSLValue CallMain(VectorValue threadArg)
    {
        try
        {
            return runner.CallFunction("main", threadArg);
        }
        catch (Exception ex) when (ex.Message.Contains("Unknown function 'main' called."))
        {
            return runner.CallFunction("main");
        }
    }

    private static HLSLValue CallMainWith(HLSLRunner r, VectorValue threadArg)
    {
        try
        {
            return r.CallFunction("main", threadArg);
        }
        catch (Exception ex) when (ex.Message.Contains("Unknown function 'main' called."))
        {
            return r.CallFunction("main");
        }
    }

    private async Task OnImmediateKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await EvaluateImmediate();
    }

    private async Task EvaluateImmediate()
    {
        string expr = immediateInput.Trim();
        if (string.IsNullOrEmpty(expr) || debugStepIndex < 0 || string.IsNullOrEmpty(debugCode)) return;
        immediateInput = "";

        int wx = Math.Max(1, warpX);
        int wy = Math.Max(1, warpY);
        int threadCount = wx * wy;

        string resultStr;
        bool isError = false;

        try
        {
            var evalRunner = new HLSLRunner(wx, wy);
            evalRunner.SetVariable("WARP_SIZE_X", new ScalarValue(ScalarType.Uint, new HLSLRegister<object>((uint)wx)));
            evalRunner.SetVariable("WARP_SIZE_Y", new ScalarValue(ScalarType.Uint, new HLSLRegister<object>((uint)wy)));

            HLSLValue evalResult = null;
            Exception evalError = null;
            int stepCount = 0;
            int targetStep = debugStepIndex;

            evalRunner.DebugHook = _ =>
            {
                if (stepCount == targetStep)
                {
                    try { evalResult = evalRunner.EvaluateExpression(expr); }
                    catch (Exception ex) { evalError = ex; }
                    throw new OperationCanceledException();
                }
                stepCount++;
            };

            var sw = new System.IO.StringWriter();
            var oldOut = Console.Out;
            Console.SetOut(sw);
            try
            {
                evalRunner.ProcessCode(debugCode);
                var threadArg = BuildThreadArg(wx, wy, threadCount);
                try { CallMainWith(evalRunner, threadArg); }
                catch (OperationCanceledException) { }
            }
            finally { Console.SetOut(oldOut); }

            if (evalError != null) { resultStr = evalError.Message; isError = true; }
            else if (evalResult != null) resultStr = FormatValue(evalResult, inspectedThread);
            else { resultStr = "(step not reached — expression may be after this point)"; isError = true; }
        }
        catch (Exception ex)
        {
            resultStr = ex.Message;
            isError = true;
        }

        immediateHistory.Add(new ImmediateEntry { Expression = expr, Result = resultStr, IsError = isError });
        StateHasChanged();
        await Task.Yield();
        await JS.InvokeVoidAsync("scrollImmediateToBottom");
    }

    private void TryExtractImage(HLSLValue result, int wx, int wy)
    {
        int threadCount = wx * wy;

        if (result is VectorValue vv)
        {
            int components = vv.Size;
            imageWidth = wx;
            imageHeight = wy;
            imagePixels = new byte[threadCount * 4];
            for (int i = 0; i < threadCount; i++)
            {
                var c = vv.Values.Get(i);
                imagePixels[i * 4 + 0] = FloatToByte(components > 0 ? Convert.ToSingle(c[0]) : 0f);
                imagePixels[i * 4 + 1] = FloatToByte(components > 1 ? Convert.ToSingle(c[1]) : 0f);
                imagePixels[i * 4 + 2] = FloatToByte(components > 2 ? Convert.ToSingle(c[2]) : 0f);
                imagePixels[i * 4 + 3] = FloatToByte(components > 3 ? Convert.ToSingle(c[3]) : 1f);
            }
            hasImage = true;
        }
        else if (result is ScalarValue sv && sv.Type != ScalarType.Void)
        {
            imageWidth = wx;
            imageHeight = wy;
            imagePixels = new byte[threadCount * 4];
            for (int i = 0; i < threadCount; i++)
            {
                byte gray = FloatToByte(Convert.ToSingle(sv.Value.Get(i)));
                imagePixels[i * 4 + 0] = gray;
                imagePixels[i * 4 + 1] = gray;
                imagePixels[i * 4 + 2] = gray;
                imagePixels[i * 4 + 3] = 255;
            }
            hasImage = true;
        }
    }

    private static byte FloatToByte(float v) => (byte)(Math.Clamp(v, 0f, 1f) * 255f + 0.5f);

    public async ValueTask DisposeAsync()
    {
        dotNetRef?.Dispose();
        await JS.InvokeVoidAsync("highlightDebugLine", 0);
        await JS.InvokeVoidAsync("setBreakpoints", Array.Empty<int>());
    }
