@page "/"
@inject IJSRuntime JS
@using UnityShaderParser.Test
@using UnityShaderParser.HLSL
@implements IAsyncDisposable

<div class="app-shell">
    <header class="topbar">
        <span class="logo">HLSL Interpreter</span>
        <div class="topbar-actions">
            <div class="warp-control">
                <label class="warp-label">Warp size</label>
                <input class="warp-input" type="number" min="1" max="32" @bind="warpX" @bind:event="oninput" disabled="@isRunning" title="Warp X" />
                <span class="warp-sep">×</span>
                <input class="warp-input" type="number" min="1" max="32" @bind="warpY" @bind:event="oninput" disabled="@isRunning" title="Warp Y" />
            </div>
            <button class="btn-run" @onclick="Run" disabled="@isRunning">
                @if (isRunning)
                {
                    <span class="spinner"></span>
                    <span>Running...</span>
                }
                else
                {
                    <span>&#9654; Run</span>
                }
            </button>
        </div>
    </header>

    <div class="main-split">
        <div class="editor-panel">
            <div class="panel-header"><span>Input</span></div>
            <div id="monaco-container" class="editor-container"></div>
        </div>

        <div class="resize-h-handle" title="Drag to resize"></div>

        <div class="output-panel">
            <div class="panel-header"><span>Output</span></div>
            <div class="output-body">
                @if (output == null && !isRunning)
                {
                    <div class="hint">Press <strong>Run</strong> or <strong>Ctrl+Enter</strong> to execute.</div>
                }
                else if (isRunning)
                {
                    <div class="hint running-hint"><span class="spinner spinner-output"></span> Running...</div>
                }
                else if (output.Length == 0 && !hasError)
                {
                    <div class="hint">No output.</div>
                }
                else
                {
                    @if (!string.IsNullOrEmpty(output))
                    {
                        <pre class="output-text">@output</pre>
                    }
                    @if (hasError)
                    {
                        <pre class="error-text">@errorMessage</pre>
                    }
                }
            </div>

            @if (hasImage)
            {
                <div class="image-section">
                    <div class="resize-v-handle" title="Drag to resize"></div>
                    <div class="panel-header"><span>Color Output</span></div>
                    <div class="image-container">
                        <canvas id="color-canvas"></canvas>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

@code {
    private static readonly string DefaultCode =
@"float4 main(uint2 thread : SV_DispatchThreadID)
{
    // Calculate UV coord
    float2 resolution = float2(WARP_SIZE_X - 1, WARP_SIZE_Y - 1);
    float2 uv = float2(thread) / resolution;

    // Debug some pixels specific pixel
    if (thread.x == 1 && thread.y <= 1)
        PRINTF(""Thread (%d, %d) value: %d"", thread.x, thread.y, uv);

    // Output some color
    return float4(uv.x, uv.y, 0.5, 1.0);
}
";

    private HLSLRunner runner = new HLSLRunner();
    private string? output;
    private bool isRunning;
    private bool hasError;
    private string errorMessage = "";
    private int warpX = 32;
    private int warpY = 32;
    private bool hasImage = false;
    private bool needsImageRender = false;
    private int imageWidth, imageHeight;
    private byte[]? imagePixels;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
            await JS.InvokeVoidAsync("initMonaco", "monaco-container", DefaultCode);

        if (needsImageRender && imagePixels != null)
        {
            needsImageRender = false;
            await JS.InvokeVoidAsync("restoreImageSectionHeight");
            await JS.InvokeVoidAsync("renderPixels", "color-canvas", imagePixels, imageWidth, imageHeight);
        }
    }

    private async Task Run()
    {
        isRunning = true;
        hasError = false;
        errorMessage = "";
        output = null;
        hasImage = false;
        imagePixels = null;
        StateHasChanged();
        await Task.Yield();

        var sw = new System.IO.StringWriter();
        var oldOut = Console.Out;
        Console.SetOut(sw);

        try
        {
            string code = await JS.InvokeAsync<string>("getMonacoValue");

            int wx = Math.Max(1, warpX);
            int wy = Math.Max(1, warpY);
            int threadCount = wx * wy;

            runner.Reset();
            runner.SetWarpSize(wx, wy);
            runner.SetVariable("WARP_SIZE_X", new ScalarValue(ScalarType.Uint, new HLSLRegister<object>((uint)wx)));
            runner.SetVariable("WARP_SIZE_Y", new ScalarValue(ScalarType.Uint, new HLSLRegister<object>((uint)wy)));
            runner.ProcessCode(code);

            var threadIds = new object[threadCount][];
            for (int i = 0; i < threadCount; i++)
                threadIds[i] = new object[] { (uint)(i % wx), (uint)(i / wx) };
            var threadArg = new VectorValue(ScalarType.Uint, new HLSLRegister<object[]>(threadIds).Converge());

            HLSLValue result;
            try
            {
                result = runner.CallFunction("main", threadArg);
            }
            catch (Exception ex) when (ex.Message.Contains("Unknown function 'main' called."))
            {
                result = runner.CallFunction("main");
            }

            TryExtractImage(result, wx, wy);
        }
        catch (Exception ex)
        {
            hasError = true;
            errorMessage = ex.Message;
        }
        finally
        {
            Console.SetOut(oldOut);
        }

        output = sw.ToString();
        needsImageRender = hasImage;
        isRunning = false;
        StateHasChanged();
    }

    private void TryExtractImage(HLSLValue result, int wx, int wy)
    {
        int threadCount = wx * wy;

        if (result is VectorValue vv)
        {
            int components = vv.Size;
            imageWidth = wx;
            imageHeight = wy;
            imagePixels = new byte[threadCount * 4];
            for (int i = 0; i < threadCount; i++)
            {
                var c = vv.Values.Get(i);
                imagePixels[i * 4 + 0] = FloatToByte(components > 0 ? Convert.ToSingle(c[0]) : 0f);
                imagePixels[i * 4 + 1] = FloatToByte(components > 1 ? Convert.ToSingle(c[1]) : 0f);
                imagePixels[i * 4 + 2] = FloatToByte(components > 2 ? Convert.ToSingle(c[2]) : 0f);
                imagePixels[i * 4 + 3] = FloatToByte(components > 3 ? Convert.ToSingle(c[3]) : 1f);
            }
            hasImage = true;
        }
        else if (result is ScalarValue sv && sv.Type != ScalarType.Void)
        {
            imageWidth = wx;
            imageHeight = wy;
            imagePixels = new byte[threadCount * 4];
            for (int i = 0; i < threadCount; i++)
            {
                byte gray = FloatToByte(Convert.ToSingle(sv.Value.Get(i)));
                imagePixels[i * 4 + 0] = gray;
                imagePixels[i * 4 + 1] = gray;
                imagePixels[i * 4 + 2] = gray;
                imagePixels[i * 4 + 3] = 255;
            }
            hasImage = true;
        }
    }

    private static byte FloatToByte(float v) => (byte)(Math.Clamp(v, 0f, 1f) * 255f + 0.5f);

    public ValueTask DisposeAsync() => ValueTask.CompletedTask;
}
