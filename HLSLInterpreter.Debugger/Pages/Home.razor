@page "/"
@inject IJSRuntime JS
@inject NavigationManager Nav
@inject PermalinkBaseUrl PermalinkBase
@inject InitialCodeOverride InitialCode
@inject TabbedEditor TabbedEditorConfig
@inject FileDialogService FileDialogs
@using HLSL
@using UnityShaderParser.HLSL
@using UnityShaderParser.Common
@using System.Globalization
@using System.IO.Compression
@using System.Text
@implements IAsyncDisposable

<div class="app-shell">
    <header class="topbar">
        <div class="topbar-left">
            <a class="btn-permalink" href="https://github.com/pema99/HLSLInterpreter" target="_blank" rel="noopener noreferrer">
                <svg width="14" height="14" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"/></svg>
                HLSLInterpreter
            </a>
            <button class="btn-permalink" @onclick="CopyPermalink" title="Copy permalink to clipboard">&#x1F517; Copy permalink</button>
        </div>

        <div class="topbar-center">
            @if (isDebugging)
            {
                <div class="debug-controls">
                    <button class="btn-dbg btn-dbg-continue" data-dbg="continue" @onclick="ContinueToBreakpoint" disabled="@(debugStepIndex >= debugTrace.Count - 1)" title="Continue (F5)"><i class="mdi mdi-play-outline"></i></button>
                    <button class="btn-dbg" data-dbg="step-over" @onclick="StepOver" disabled="@(debugStepIndex >= debugTrace.Count - 1)" title="Step over (F10)"><i class="mdi mdi-debug-step-over"></i></button>
                    <button class="btn-dbg" data-dbg="step-in" @onclick="StepForward" disabled="@(debugStepIndex >= debugTrace.Count - 1)" title="Step in (F11)"><i class="mdi mdi-debug-step-into icon-step-into"></i></button>
                    <button class="btn-dbg" data-dbg="step-out" @onclick="StepOut" disabled="@(debugStepIndex >= debugTrace.Count - 1)" title="Step out (F12)"><i class="mdi mdi-debug-step-out icon-step-out"></i></button>
                    <div class="dbg-controls-sep"></div>
                    <button class="btn-dbg btn-dbg-continue-back" data-dbg="continue-back" @onclick="ContinueToBreakpointBack" disabled="@(debugStepIndex <= 0)" title="Continue back (Shift+F5)"><i class="mdi mdi-play-outline btn-icon-mirror"></i></button>
                    <button class="btn-dbg" data-dbg="step-over-back" @onclick="StepOverBack" disabled="@(debugStepIndex <= 0)" title="Step over back (Shift+F10)"><i class="mdi mdi-debug-step-over btn-icon-mirror"></i></button>
                    <button class="btn-dbg" data-dbg="step-in-back" @onclick="StepBack" disabled="@(debugStepIndex <= 0)" title="Step in back (Shift+F11)"><i class="mdi mdi-debug-step-into icon-step-into-back"></i></button>
                    <button class="btn-dbg" data-dbg="step-out-back" @onclick="StepOutBack" disabled="@(debugStepIndex <= 0)" title="Step out back (Shift+F12)"><i class="mdi mdi-debug-step-out icon-step-out-back"></i></button>
                </div>
            }
        </div>

        <div class="topbar-right">
            @if (isDebugging)
            {
                <div class="thread-selector">
                    <label class="warp-label">Thread</label>
                    <input class="warp-input" type="number" min="0" max="@(warpX * warpY - 1)"
                           @bind="inspectedThread" @bind:event="oninput" />
                    <span class="warp-sep">(@(inspectedThread % warpX), @(inspectedThread / warpX))</span>
                </div>
            }
            <button class="btn-settings" @onclick="OpenSettings" title="Settings">&#x2699;&#xFE0F; Settings</button>
            <button class="btn-run" @onclick="Run" disabled="@(isRunning || isDebugging)">
                @if (isRunning)
                {
                    <span class="spinner"></span>
                    <span>Running...</span>
                }
                else
                {
                    <span>&#9654; Run</span>
                }
            </button>
            @if (isDebugging)
            {
                <button class="btn-stop" @onclick="ExitDebug" title="Stop debugging">&#x25A0; Stop</button>
            }
            else
            {
                <button class="btn-debug-start" @onclick="StartDebug" disabled="@isRunning" title="Debug (record execution trace)">&#x1F41E; Debug</button>
            }
        </div>
    </header>

    <div class="main-split">
        <div class="editor-panel">
            <div class="panel-header">
                @if (TabbedEditorConfig.Enabled)
                {
                    <div class="editor-toolbar-group">
                        <button class="btn-editor-toolbar" @onclick="OpenFileDialog" title="Open file">Open</button>
                        <button class="btn-editor-toolbar" @onclick="SaveFileDialog" title="Save">Save</button>
                        <button class="btn-editor-toolbar" @onclick="SaveFileAsDialog" title="Save As">Save As</button>
                    </div>
                }
                else
                {
                    <span>Input</span>
                }
                <select class="footer-select" title="Font size" @onchange="OnFontSizeChanged">
                    @foreach (var size in fontSizes)
                    {
                        <option value="@size" selected="@(size == fontSize)">@size</option>
                    }
                </select>
            </div>
            @if (TabbedEditorConfig.Enabled)
            {
                <div class="editor-tabs">
                    @for (int i = 0; i < editorTabs.Count; i++)
                    {
                        var idx = i;
                        <div class="editor-tab @(idx == activeTabIndex ? "active" : "")"
                             @onclick="() => SwitchTab(idx)">
                            @editorTabs[idx].Name
                            <span class="editor-tab-close" @onclick="() => CloseTab(idx)" @onclick:stopPropagation>&#x2715;</span>
                        </div>
                    }
                </div>
            }
            <div id="monaco-container" class="editor-container"></div>
        </div>

        <div class="resize-h-handle" title="Drag to resize"></div>

        @{
            var _dbgStep = (isDebugging && debugStepIndex >= 0 && debugStepIndex < debugTrace.Count)
                ? debugTrace[debugStepIndex] : null;
            var _frameIdx = _dbgStep != null
                ? Math.Clamp(selectedFrame, 0, Math.Max(0, _dbgStep.FrameThreadStates.Length - 1)) : 0;
            var threadStates = (_dbgStep != null && _frameIdx < _dbgStep.FrameThreadStates.Length)
                ? _dbgStep.FrameThreadStates[_frameIdx]
                : Array.Empty<HLSLExecutionState.ThreadState>();
        }
        <div class="output-panel">
            @if (isDebugging)
            {
                <!-- Variables -->
                <div class="debug-section debug-section-vars @(varsCollapsed ? "section-collapsed" : "")">
                    <div class="panel-header collapsible-header" @onclick="() => varsCollapsed = !varsCollapsed">
                        <div class="panel-header-left">
                            <span class="collapse-icon @(varsCollapsed ? "" : "expanded")">&#x203A;</span>
                            <span>Variables</span>
                        </div>
                    </div>
                    @if (!varsCollapsed)
                    {
                        <div class="output-body debug-vars-body">
                            @if (debugStepIndex >= 0 && debugStepIndex < debugTrace.Count)
                            {
                                var step = debugTrace[debugStepIndex];
                                var localFrameIdx = Math.Clamp(selectedFrame, 0, Math.Max(0, step.FrameVariables.Length - 1));
                                var locals = localFrameIdx < step.FrameVariables.Length ? step.FrameVariables[localFrameIdx] : null;
                                var globals = step.GlobalVariables;

                                bool hasLocals = locals != null && locals.Count > 0;
                                bool hasGlobals = globals != null && globals.Count > 0;

                                if (!hasLocals && !hasGlobals)
                                {
                                    <div class="hint">No variables in scope.</div>
                                }
                                else
                                {
                                    <div class="var-list">
                                        @{
                                            var rows = new List<VarRow>();
                                            if (hasLocals)
                                                foreach (var kvp in locals!)
                                                    BuildVarRows(rows, kvp.Key, kvp.Value, 0, kvp.Key);
                                            var globalRows = new List<VarRow>();
                                            if (hasGlobals)
                                                foreach (var kvp in globals!)
                                                    BuildVarRows(globalRows, kvp.Key, kvp.Value, 0, "g:" + kvp.Key);
                                        }
                                        @if (hasLocals)
                                        {
                                            <div class="var-subsection-header" @onclick="() => localVarsCollapsed = !localVarsCollapsed">
                                                <span class="collapse-icon @(localVarsCollapsed ? "" : "expanded")">&#x203A;</span>
                                                <span>Locals</span>
                                            </div>
                                            if (!localVarsCollapsed)
                                            {
                                                foreach (var row in rows)
                                                {
                                                    var rowPath = row.Path;
                                                    <div class="var-row" style="padding-left: @(6 + row.Depth * 18)px">
                                                        @if (row.IsExpandable)
                                                        {
                                                            <span class="var-toggle @(expandedVarPaths.Contains(rowPath) ? "expanded" : "")"
                                                                  @onclick="() => ToggleVarPath(rowPath)">&#x25BA;</span>
                                                        }
                                                        else
                                                        {
                                                            <span class="var-toggle-spacer"></span>
                                                        }
                                                        <span class="var-row-name" title="@row.Name">@row.Name</span>
                                                        <span class="var-row-value">@FormatValue(row.Value, inspectedThread)</span>
                                                    </div>
                                                }
                                            }
                                        }
                                        @if (hasGlobals)
                                        {
                                            <div class="var-subsection-header" @onclick="() => globalVarsCollapsed = !globalVarsCollapsed">
                                                <span class="collapse-icon @(globalVarsCollapsed ? "" : "expanded")">&#x203A;</span>
                                                <span>Globals</span>
                                            </div>
                                            if (!globalVarsCollapsed)
                                            {
                                                foreach (var row in globalRows)
                                                {
                                                    var rowPath = row.Path;
                                                    <div class="var-row" style="padding-left: @(6 + row.Depth * 18)px">
                                                        @if (row.IsExpandable)
                                                        {
                                                            <span class="var-toggle @(expandedVarPaths.Contains(rowPath) ? "expanded" : "")"
                                                                  @onclick="() => ToggleVarPath(rowPath)">&#x25BA;</span>
                                                        }
                                                        else
                                                        {
                                                            <span class="var-toggle-spacer"></span>
                                                        }
                                                        <span class="var-row-name" title="@row.Name">@row.Name</span>
                                                        <span class="var-row-value">@FormatValue(row.Value, inspectedThread)</span>
                                                    </div>
                                                }
                                            }
                                        }
                                    </div>
                                }
                            }
                            else
                            {
                                <div class="hint">Use Step or Continue to inspect variables.</div>
                            }
                        </div>
                        <div class="resize-v-handle" title="Drag to resize"></div>
                    }
                </div>

                <!-- Call Stack + Execution State -->
                <div class="debug-section debug-section-callstack @(callStackCollapsed ? "section-collapsed" : "")">
                    <div class="panel-header collapsible-header" @onclick="() => { callStackCollapsed = !callStackCollapsed; if (!callStackCollapsed) needsThreadGridInit = true; }">
                        <div class="panel-header-left">
                            <span class="collapse-icon @(callStackCollapsed ? "" : "expanded")">&#x203A;</span>
                            <span>Call Stack</span>
                        </div>
                        @if (!callStackCollapsed && threadStates.Length > 0)
                        {
                            <span class="thread-legend">
                                <span class="tl-dot tc-active"></span>Active thread
                                <span class="tl-dot tc-diverged"></span>Inactive thread
                            </span>
                        }
                    </div>
                    @if (!callStackCollapsed)
                    {
                        <div class="callstack-exec-body">
                            <div class="callstack-pane">
                                @if (debugStepIndex >= 0 && debugStepIndex < debugTrace.Count)
                                {
                                    var stack = debugTrace[debugStepIndex].CallStack;
                                    <table class="var-table">
                                        <tbody>
                                            @for (int i = 0; i < stack.Length; i++)
                                            {
                                                var fi = i;
                                                <tr class="@(fi == selectedFrame ? "callstack-selected" : "")"
                                                    @onclick="() => selectedFrame = fi"
                                                    style="cursor: pointer;">
                                                    <td class="var-name">@stack[i]</td>
                                                </tr>
                                            }
                                            <tr style="cursor: default;">
                                                <td class="var-name" style="color: #555; font-style: italic;">[Globals]</td>
                                            </tr>
                                        </tbody>
                                    </table>
                                }
                                else
                                {
                                    <div class="hint">Use Step or Continue to inspect call stack.</div>
                                }
                            </div>
                            @if (threadStates.Length > 0)
                            {
                                <div class="resize-inner-h-handle" id="callstack-exec-divider"></div>
                                <div class="exec-state-body" id="thread-grid-container">
                                    <div class="thread-grid">
                                        @for (int ti = 0; ti < threadStates.Length; ti++)
                                        {
                                            var tidx = ti;
                                            var state = threadStates[ti];
                                            var stateClass = state switch {
                                                HLSLExecutionState.ThreadState.Active    => "tc-active",
                                                HLSLExecutionState.ThreadState.Inactive  => "tc-diverged",
                                                HLSLExecutionState.ThreadState.Suspended => "tc-suspended",
                                                _ => ""
                                            };
                                            var label = $"Thread ({ti % warpX}, {ti / warpX}) – {state}";
                                            <div class="thread-cell @stateClass @(tidx == inspectedThread ? "tc-selected" : "")"
                                                 title="@label"
                                                 @onclick="() => inspectedThread = tidx"></div>
                                        }
                                    </div>
                                </div>
                            }
                        </div>
                        <div class="resize-v-handle" title="Drag to resize"></div>
                    }
                </div>

                <!-- Immediate -->
                <div class="debug-section debug-section-immediate @(immediateCollapsed ? "section-collapsed" : "")">
                    <div class="panel-header collapsible-header" @onclick="() => immediateCollapsed = !immediateCollapsed">
                        <div class="panel-header-left">
                            <span class="collapse-icon @(immediateCollapsed ? "" : "expanded")">&#x203A;</span>
                            <span>Immediate</span>
                        </div>
                    </div>
                    @if (!immediateCollapsed)
                    {
                        <div class="output-body imm-body">
                            @if (immediateHistory.Count == 0)
                            {
                                <div class="hint">Evaluate expressions in the current scope.</div>
                            }
                            else
                            {
                                <div class="imm-history">
                                    @foreach (var entry in immediateHistory)
                                    {
                                        <div class="imm-entry">
                                            <div class="imm-expr"><span class="imm-prompt">&gt;</span> @entry.Expression</div>
                                            <div class="imm-result @(entry.IsError ? "imm-error" : "")">@entry.Result</div>
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                        <div class="imm-input-row">
                            <span class="imm-prompt-inline">&gt;</span>
                            <input class="imm-input" type="text" placeholder="Expression..."
                                   @bind="immediateInput" @bind:event="oninput"
                                   @onkeydown="OnImmediateKeyDown" />
                            <button class="imm-eval-btn" @onclick="EvaluateImmediate" disabled="@(debugStepIndex < 0)">Eval</button>
                        </div>
                        <div class="resize-v-handle" title="Drag to resize"></div>
                    }
                </div>

                <!-- Console Output -->
                <div class="debug-section debug-section-console @(consoleCollapsed ? "section-collapsed" : "")">
                    <div class="panel-header collapsible-header" @onclick="() => consoleCollapsed = !consoleCollapsed">
                        <div class="panel-header-left">
                            <span class="collapse-icon @(consoleCollapsed ? "" : "expanded")">&#x203A;</span>
                            <span>Console</span>
                        </div>
                    </div>
                    @if (!consoleCollapsed)
                    {
                        <div class="output-body debug-console-body">
                            @if (hasError)
                            {
                                <pre class="error-text">@errorMessage</pre>
                            }
                            else if (!string.IsNullOrEmpty(CurrentDebugOutput))
                            {
                                <pre class="output-text">@CurrentDebugOutput</pre>
                            }
                            else
                            {
                                <div class="hint">No output yet.</div>
                            }
                        </div>
                        <div class="resize-v-handle" title="Drag to resize"></div>
                    }
                </div>

                <!-- Color Output -->
                @if (hasImage)
                {
                    <div class="debug-section debug-section-image @(imageCollapsed ? "section-collapsed" : "")">
                        <div class="panel-header collapsible-header" @onclick="ToggleImageSection">
                            <div class="panel-header-left">
                                <span class="collapse-icon @(imageCollapsed ? "" : "expanded")">&#x203A;</span>
                                <span>Color Output</span>
                            </div>
                        </div>
                        @if (!imageCollapsed)
                        {
                            <div class="image-container">
                                <canvas id="color-canvas"></canvas>
                            </div>
                            <div class="resize-v-handle" title="Drag to resize"></div>
                        }
                    </div>
                }

                <div class="debug-panel-spacer"></div>
            }
            else
            {
                <!-- Console -->
                <div class="debug-section debug-section-console @(consoleCollapsed ? "section-collapsed" : "")"
                     style="--section-h: 240px;">
                    <div class="panel-header collapsible-header" @onclick="() => consoleCollapsed = !consoleCollapsed">
                        <div class="panel-header-left">
                            <span class="collapse-icon @(consoleCollapsed ? "" : "expanded")">&#x203A;</span>
                            <span>Console</span>
                        </div>
                    </div>
                    @if (!consoleCollapsed)
                    {
                        <div class="output-body">
                            @if (output == null && !isRunning)
                            {
                                <div class="hint">Press <strong>Run</strong> or <strong>Ctrl+Enter</strong> to execute.</div>
                            }
                            else if (isRunning)
                            {
                                <div class="hint running-hint"><span class="spinner spinner-output"></span> Running...</div>
                            }
                            else if (output!.Length == 0 && !hasError)
                            {
                                <div class="hint">No output.</div>
                            }
                            else if (hasError)
                            {
                                <pre class="error-text">@errorMessage</pre>
                            }
                            else
                            {
                                <pre class="output-text">@output</pre>
                            }
                        </div>
                        <div class="resize-v-handle" title="Drag to resize"></div>
                    }
                </div>

                <!-- Color Output -->
                @if (hasImage)
                {
                    <div class="debug-section debug-section-image @(imageCollapsed ? "section-collapsed" : "")">
                        <div class="panel-header collapsible-header" @onclick="ToggleImageSection">
                            <div class="panel-header-left">
                                <span class="collapse-icon @(imageCollapsed ? "" : "expanded")">&#x203A;</span>
                                <span>Color Output</span>
                            </div>
                        </div>
                        @if (!imageCollapsed)
                        {
                            <div class="image-container">
                                <canvas id="color-canvas"></canvas>
                            </div>
                            <div class="resize-v-handle" title="Drag to resize"></div>
                        }
                    </div>
                }

                <div class="debug-panel-spacer"></div>
            }
        </div>
    </div>
</div>

@if (showSettings)
{
    <div class="modal-overlay" @onclick="CloseSettings">
        <div class="modal-dialog" @onclick:stopPropagation="true">
            <div class="modal-header">Settings</div>
            <div class="modal-body">
                <div class="settings-row">
                    <label class="settings-label">Entry point</label>
                    <input class="settings-text-input" type="text" @bind="entryPoint" @bind:event="oninput" disabled="@(isRunning || isDebugging)" title="Function name to call" />
                </div>
                <div class="settings-row">
                    <label class="settings-label">Group offset</label>
                    <div class="warp-control">
                        <input class="warp-input" type="number" min="0" @bind="groupOffsetX" @bind:event="oninput" disabled="@(isRunning || isDebugging)" title="Group X" />
                        <span class="warp-sep">×</span>
                        <input class="warp-input" type="number" min="0" @bind="groupOffsetY" @bind:event="oninput" disabled="@(isRunning || isDebugging)" title="Group Y" />
                    </div>
                </div>
                <div class="settings-row">
                    <label class="settings-label">Warp size</label>
                    <div class="warp-control">
                        <input class="warp-input" type="number" min="1" max="32" @bind="warpX" @bind:event="oninput" disabled="@(isRunning || isDebugging)" title="Warp X" />
                        <span class="warp-sep">×</span>
                        <input class="warp-input" type="number" min="1" max="32" @bind="warpY" @bind:event="oninput" disabled="@(isRunning || isDebugging)" title="Warp Y" />
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn-modal-save" @onclick="CloseSettings">Close</button>
            </div>
        </div>
    </div>
}

@code {
    private static readonly string DefaultCode =
@"static float TWIST = 12.0;
static float PERIOD = 32.0;
static float ARMS = 3.0;

float3 hueShift (float3 color, float shift)
{
    float3 axis = 0.55735;
    float3 grayscale = dot(0.55735, color);
    float3 radial = color - axis;
    float3 tangent = cross(axis, radial);
    return radial * cos(shift * 6.2832) +
        tangent * sin(shift * 6.2832) + axis;
}

float4 main(float4 position : SV_Position) : SV_Target
{
    float2 res = float2(WARP_SIZE_X, WARP_SIZE_Y);
    float2 uv = (position.xy / res) - 0.5;
    float dist = length(uv);
    float angle = atan2(uv.y, uv.x) + 0.4;
    float wave = sin(dist * TWIST - angle * ARMS);
    wave = wave * 0.5 + 0.5;
    if (wave < 0.5)
    {
        PRINTF(""First branch taken due to %d wave value!"", wave);
        float3 base = float3(1.0, 0.3, 0.1);
        float3 color = hueShift(base, wave + dist);
        return float4(color, 1);
    }
    else
    {
        float periodic = sin(dist*PERIOD);
        float inverse = cos(dist*PERIOD);
        return float4(periodic, 0, inverse, 1);
    }
}
";

    private static readonly int[] fontSizes = { 12, 13, 14, 15, 16, 18, 20, 22, 24, 26, 28, 30, 32, 34, 36 };
    private int fontSize = 16;

    private async Task OnFontSizeChanged(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out int size))
        {
            fontSize = size;
            await JS.InvokeVoidAsync("setMonacoFontSize", size);
        }
    }

    // --- Core state ---
    private HLSLRunner runner = new HLSLRunner();
    // --- Tabs ---
    private class EditorTab { public string Name = ""; public string Code = ""; public string? Path = null; }
    private List<EditorTab> editorTabs = new();
    private int activeTabIndex = 0;

    private async Task SwitchTab(int index)
    {
        if (index == activeTabIndex) return;
        editorTabs[activeTabIndex].Code = await JS.InvokeAsync<string>("getMonacoValue");
        if (isDebugging) await JS.InvokeVoidAsync("highlightDebugLine", 0);
        activeTabIndex = index;
        await JS.InvokeVoidAsync("setMonacoValue", editorTabs[activeTabIndex].Code);
        if (isDebugging && activeTabIndex == debugTabIndex)
            await JS.InvokeVoidAsync("highlightDebugLine", currentDebugLine);
    }

    private async Task CloseTab(int index)
    {
        if (editorTabs.Count <= 1) return;
        if (index == activeTabIndex)
        {
            int newActive = index > 0 ? index - 1 : 1;
            activeTabIndex = newActive;
            await JS.InvokeVoidAsync("setMonacoValue", editorTabs[newActive].Code);
        }
        editorTabs.RemoveAt(index);
        if (activeTabIndex > index) activeTabIndex--;
    }

    private async Task OpenFileDialog()
    {
        var (path, content) = await FileDialogs.OpenFile();
        if (path == null || content == null) return;
        var existing = editorTabs.FindIndex(t => t.Path == path);
        if (existing >= 0) { await SwitchTab(existing); return; }
        editorTabs[activeTabIndex].Code = await JS.InvokeAsync<string>("getMonacoValue");
        string name = System.IO.Path.GetFileName(path);
        editorTabs.Add(new EditorTab { Name = name, Code = content, Path = path });
        activeTabIndex = editorTabs.Count - 1;
        await JS.InvokeVoidAsync("setMonacoValue", content);
        StateHasChanged();
    }

    private async Task SaveFileDialog()
    {
        string code = await JS.InvokeAsync<string>("getMonacoValue");
        string? savedPath = await FileDialogs.SaveFile(code, editorTabs[activeTabIndex].Path);
        if (savedPath == null) return;
        editorTabs[activeTabIndex].Path = savedPath;
        editorTabs[activeTabIndex].Name = System.IO.Path.GetFileName(savedPath);
        editorTabs[activeTabIndex].Code = code;
        StateHasChanged();
    }

    private async Task SaveFileAsDialog()
    {
        string code = await JS.InvokeAsync<string>("getMonacoValue");
        string? savedPath = await FileDialogs.SaveFileAs(code);
        if (savedPath == null) return;
        editorTabs[activeTabIndex].Path = savedPath;
        editorTabs[activeTabIndex].Name = System.IO.Path.GetFileName(savedPath);
        editorTabs[activeTabIndex].Code = code;
        StateHasChanged();
    }

    [JSInvokable]
    public async Task OpenFileInTab(string name, string content, string? path = null)
    {
        if (!TabbedEditorConfig.Enabled) return;
        var existing = editorTabs.FindIndex(t => t.Name == name);
        if (existing >= 0)
        {
            await SwitchTab(existing);
        }
        else
        {
            editorTabs[activeTabIndex].Code = await JS.InvokeAsync<string>("getMonacoValue");
            editorTabs.Add(new EditorTab { Name = name, Code = content, Path = string.IsNullOrEmpty(path) ? null : path });
            activeTabIndex = editorTabs.Count - 1;
            await JS.InvokeVoidAsync("setMonacoValue", content);
        }
        StateHasChanged();
    }

