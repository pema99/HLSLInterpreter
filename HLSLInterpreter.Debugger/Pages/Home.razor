    private sealed class ImmediateEntry
    {
        public string Expression { get; init; } = "";
        public string Result { get; init; } = "";
        public bool IsError { get; init; }
    }

    private int inspectedThread
    {
        get => _inspectedThread;
        set => _inspectedThread = Math.Clamp(value, 0, Math.Max(0, warpX * warpY - 1));
    }

    private int currentDebugLine =>
        (debugStepIndex >= 0 && debugStepIndex < debugTrace.Count)
            ? debugTrace[debugStepIndex].Line : 0;

    private sealed class DebugStep
    {
        public int Line { get; init; }
        public string[] CallStack { get; init; } = Array.Empty<string>();
        public int CallDepth => CallStack.Length;
        // Per-frame local variables, index 0 = innermost (current) frame
        public Dictionary<string, HLSLValue>[] FrameVariables { get; init; } = Array.Empty<Dictionary<string, HLSLValue>>();
        public Dictionary<string, HLSLValue> GlobalVariables { get; init; } = new();
        public int OutputOffset { get; init; }
        public HLSLExecutionState.ThreadState[][] FrameThreadStates { get; init; } = Array.Empty<HLSLExecutionState.ThreadState[]>();
    }

    // Console output visible at the current debug step (output produced by statements executed so far).
    private string CurrentDebugOutput
    {
        get
        {
            if (output == null || debugStepIndex < 0) return "";
            // Output produced *through* step N ends at the start of step N+1's offset (or total length if last).
            int endOffset = debugStepIndex < debugTrace.Count - 1
                ? debugTrace[debugStepIndex + 1].OutputOffset
                : output.Length;
            return output[..Math.Min(endOffset, output.Length)];
        }
    }

    protected override void OnInitialized()
    {
        if (TabbedEditorConfig.Enabled)
            editorTabs.Add(new EditorTab { Name = InitialCode.Name ?? "new.hlsl", Code = InitialCode.Code ?? DefaultCode, Path = InitialCode.Path });
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            dotNetRef = DotNetObjectReference.Create(this);

            // Load code from permalink, file argument, or default
            string initialCode = InitialCode.Code ?? DefaultCode;
            var param = GetQueryParam(Nav.Uri, "c");
            if (!string.IsNullOrEmpty(param))
            {
                try { initialCode = DecompressCode(param); }
                catch { }
            }

            if (TabbedEditorConfig.Enabled && editorTabs.Count > 0)
                editorTabs[0].Code = initialCode;

            await JS.InvokeVoidAsync("initMonaco", "monaco-container", initialCode, dotNetRef);

            if (TabbedEditorConfig.Enabled)
                FileDialogs.FileDropped = async (name, content, path) => await OpenFileInTab(name, content, path);
        }

        if (needsSectionHeightRestore)
        {
            needsSectionHeightRestore = false;
            await JS.InvokeVoidAsync("restoreSectionHeights");
        }

        if (needsImageRender && imagePixels != null)
        {
            needsImageRender = false;
            await JS.InvokeVoidAsync("restoreImageSectionHeight");
            await JS.InvokeVoidAsync("renderPixels", "color-canvas", imagePixels, imageWidth, imageHeight);
        }

        if (needsThreadGridInit)
        {
            needsThreadGridInit = false;
            await JS.InvokeVoidAsync("initThreadGridResize", "thread-grid-container", warpX, warpY);
        }
    }

    // --- Run (normal mode) ---
    private async Task Run()
    {
        isRunning = true;
        hasError = false;
        errorMessage = "";
        lastException = null;
        output = null;
        hasImage = false;
        imagePixels = null;
        StateHasChanged();
        await Task.Yield();

        var sw = new System.IO.StringWriter();
        var oldOut = Console.Out;
        Console.SetOut(sw);

        try
        {
            string code = await JS.InvokeAsync<string>("getMonacoValue");
            int wx = Math.Max(1, warpX);
            int wy = Math.Max(1, warpY);
            int threadCount = wx * wy;

            runner.DebugHook = null;
            runner.Reset();
            runner.SetWarpSize(wx, wy);
            runner.SetVariable("WARP_SIZE_X", new ScalarValue(ScalarType.Uint, new HLSLRegister<object>((uint)wx)));
            runner.SetVariable("WARP_SIZE_Y", new ScalarValue(ScalarType.Uint, new HLSLRegister<object>((uint)wy)));
            runner.ProcessCode(code, MakeParserConfig());

            var threadArg = BuildThreadArg(wx, wy, threadCount, groupOffsetX, groupOffsetY);
            HLSLValue result = CallMain(threadArg);
            TryExtractImage(result, wx, wy);
        }
        catch (Exception ex)
        {
            hasError = true;
            errorMessage = ex.Message;
        }
        finally
        {
            Console.SetOut(oldOut);
        }

        output = sw.ToString();
        needsImageRender = hasImage;
        isRunning = false;
        StateHasChanged();
    }

    // --- Debug: record trace ---
    private async Task StartDebug()
    {
        isRunning = true;
        hasError = false;
        errorMessage = "";
        lastException = null;
        output = null;
        hasImage = false;
        imagePixels = null;
        debugTrace = new();
        debugStepIndex = -1;
        await JS.InvokeVoidAsync("saveSectionHeights");
        StateHasChanged();
        await Task.Yield();

        var sw = new System.IO.StringWriter();
        var oldOut = Console.Out;
        Console.SetOut(sw);

        try
        {
            string code = await JS.InvokeAsync<string>("getMonacoValue");
            debugCode = code;
            immediateHistory = new();
            int wx = Math.Max(1, warpX);
            int wy = Math.Max(1, warpY);
            int threadCount = wx * wy;

            runner.Reset();
            runner.SetWarpSize(wx, wy);
            runner.SetVariable("WARP_SIZE_X", new ScalarValue(ScalarType.Uint, new HLSLRegister<object>((uint)wx)));
            runner.SetVariable("WARP_SIZE_Y", new ScalarValue(ScalarType.Uint, new HLSLRegister<object>((uint)wy)));

            runner.DebugHook = node =>
            {
                Dictionary<string, HLSLValue> CopyFrame(Dictionary<string, HLSLValue> frame)
                {
                    var copy = new Dictionary<string, HLSLValue>();
                    foreach (var kvp in frame)
                    {
                        HLSLValue val = kvp.Value is ReferenceValue rv ? rv.Get() : kvp.Value;
                        try { copy[kvp.Key] = val?.Copy() ?? val!; }
                        catch { copy[kvp.Key] = val!; }
                    }
                    return copy;
                }

                var frameCopies = runner.GetVariablesPerFrame().Select(CopyFrame).ToArray();
                var globalCopy = CopyFrame(runner.GetGlobalVariables());

                debugTrace.Add(new DebugStep
                {
                    Line = node.Span.Start.Line,
                    CallStack = runner.GetCallStack(),
                    FrameVariables = frameCopies,
                    GlobalVariables = globalCopy,
                    OutputOffset = sw.GetStringBuilder().Length,
                    FrameThreadStates = runner.GetThreadStatesPerFrame()
                });
            };

            runner.ProcessCode(code, MakeParserConfig(), out var diagnostics, out _);
            var compileErrors = diagnostics.Where(d => (d.Kind & DiagnosticFlags.OnlyErrors) != 0).ToList();
            if (compileErrors.Count > 0)
            {
                hasError = true;
                errorMessage = string.Join("\n", compileErrors.Select(d => $"Line {d.Location.Line}, col {d.Location.Column}: {d.Text}"));
                lastException = null;
            }
            else
            {
                var threadArg = BuildThreadArg(wx, wy, threadCount, groupOffsetX, groupOffsetY);
                HLSLValue result = CallMain(threadArg);
                TryExtractImage(result, wx, wy);
            }
        }
        catch (Exception ex)
        {
            hasError = true;
            errorMessage = ex.Message;
            lastException = ex;
        }
        finally
        {
            runner.DebugHook = null;
            Console.SetOut(oldOut);
        }

        output = sw.ToString();
        needsImageRender = hasImage;
        isRunning = false;

        if (hasError && !(lastException is HLSLRunner.TestFailException && debugTrace.Count > 0))
        {
            // Compile/parse/runtime error, nothing useful to debug
            needsSectionHeightRestore = true;
            StateHasChanged();
            return;
        }

        isDebugging = true;
        await JS.InvokeVoidAsync("setMonacoReadOnly", true);
        debugTabIndex = activeTabIndex;
        immediateCollapsed = false;
        // Keep console open when failing so the error is visible
        consoleCollapsed = !hasError;
        imageCollapsed = true;

        // When failing, start at the last recorded step so the failing statement is highlighted
        if (debugTrace.Count > 0)
        {
            debugStepIndex = hasError ? debugTrace.Count - 1 : 0;
            await JS.InvokeVoidAsync("highlightDebugLine", currentDebugLine);
        }

        needsSectionHeightRestore = true;
        needsThreadGridInit = true;
        StateHasChanged();
    }

    // --- Debug navigation ---
    private async Task EnsureOnDebugTab()
    {
        if (debugTabIndex >= 0 && activeTabIndex != debugTabIndex)
            await SwitchTab(debugTabIndex);
    }

    private async Task StepForward()
    {
        await EnsureOnDebugTab();
        if (debugStepIndex < debugTrace.Count - 1)
        {
            debugStepIndex++;
            selectedFrame = 0;
            await JS.InvokeVoidAsync("highlightDebugLine", currentDebugLine);
            StateHasChanged();
        }
    }

    private async Task StepBack()
    {
        await EnsureOnDebugTab();
        if (debugStepIndex > 0)
        {
            debugStepIndex--;
            selectedFrame = 0;
            await JS.InvokeVoidAsync("highlightDebugLine", currentDebugLine);
            StateHasChanged();
        }
    }

    private async Task StepOver()
    {
        await EnsureOnDebugTab();
        if (debugStepIndex >= debugTrace.Count - 1) return;
        int depth = debugTrace[debugStepIndex].CallDepth;
        int next = debugStepIndex + 1;
        if (depth > 0)
        {
            while (next < debugTrace.Count - 1 && debugTrace[next].CallDepth > depth)
                next++;
        }
        debugStepIndex = next;
        selectedFrame = 0;
        await JS.InvokeVoidAsync("highlightDebugLine", currentDebugLine);
        StateHasChanged();
    }

    private async Task StepOut()
    {
        await EnsureOnDebugTab();
        if (debugStepIndex >= debugTrace.Count - 1) return;
        int depth = debugTrace[debugStepIndex].CallDepth;
        int next = debugStepIndex + 1;
        while (next < debugTrace.Count - 1 && debugTrace[next].CallDepth >= depth)
            next++;
        debugStepIndex = next;
        selectedFrame = 0;
        await JS.InvokeVoidAsync("highlightDebugLine", currentDebugLine);
        StateHasChanged();
    }

    private async Task ContinueToBreakpoint()
    {
        await EnsureOnDebugTab();
        int next = debugStepIndex + 1;
        while (next < debugTrace.Count && !breakpoints.Contains(debugTrace[next].Line))
            next++;
        debugStepIndex = Math.Min(next, debugTrace.Count - 1);
        selectedFrame = 0;
        await JS.InvokeVoidAsync("highlightDebugLine", currentDebugLine);
        StateHasChanged();
    }

    private async Task ContinueToBreakpointBack()
    {
        await EnsureOnDebugTab();
        int prev = debugStepIndex - 1;
        while (prev > 0 && !breakpoints.Contains(debugTrace[prev].Line))
            prev--;
        debugStepIndex = Math.Max(prev, 0);
        selectedFrame = 0;
        await JS.InvokeVoidAsync("highlightDebugLine", currentDebugLine);
        StateHasChanged();
    }

    private async Task StepOverBack()
    {
        await EnsureOnDebugTab();
        if (debugStepIndex <= 0) return;
        int depth = debugTrace[debugStepIndex].CallDepth;
        int prev = debugStepIndex - 1;
        while (prev > 0 && debugTrace[prev].CallDepth > depth)
            prev--;
        debugStepIndex = prev;
        selectedFrame = 0;
        await JS.InvokeVoidAsync("highlightDebugLine", currentDebugLine);
        StateHasChanged();
    }

    private async Task StepOutBack()
    {
        await EnsureOnDebugTab();
        if (debugStepIndex <= 0) return;
        int depth = debugTrace[debugStepIndex].CallDepth;
        int prev = debugStepIndex - 1;
        while (prev > 0 && debugTrace[prev].CallDepth >= depth)
            prev--;
        debugStepIndex = prev;
        selectedFrame = 0;
        await JS.InvokeVoidAsync("highlightDebugLine", currentDebugLine);
        StateHasChanged();
    }


