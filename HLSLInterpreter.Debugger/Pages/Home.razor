    // --- Value formatting ---
    // --- Hierarchical variable list ---
    private sealed class VarRow
    {
        public string Path = "";
        public string Name = "";
        public HLSLValue Value = null!;
        public int Depth;
        public bool IsExpandable;
    }

    private void ToggleVarPath(string path)
    {
        if (!expandedVarPaths.Remove(path))
            expandedVarPaths.Add(path);
    }

    private void BuildVarRows(List<VarRow> rows, string name, HLSLValue value, int depth, string path)
    {
        if (value is ReferenceValue rv) value = rv.Get();
        bool isExpandable = value is StructValue or ArrayValue or MatrixValue;
        rows.Add(new VarRow { Path = path, Name = name, Value = value, Depth = depth, IsExpandable = isExpandable });

        if (!isExpandable || !expandedVarPaths.Contains(path)) return;

        if (value is StructValue sv)
        {
            foreach (var kvp in sv.Members)
                BuildVarRows(rows, kvp.Key, kvp.Value, depth + 1, $"{path}.{kvp.Key}");
        }
        else if (value is ArrayValue av)
        {
            for (int i = 0; i < av.Values.Length; i++)
                BuildVarRows(rows, $"[{i}]", av.Values[i], depth + 1, $"{path}[{i}]");
        }
        else if (value is MatrixValue mv)
        {
            for (int r = 0; r < mv.Rows; r++)
            {
                VectorValue rowVec;
                int cols = mv.Columns;
                if (mv.Values.IsVarying)
                {
                    var perThread = mv.Values.VaryingValues
                        .Select(elems => elems.Skip(r * cols).Take(cols).ToArray() as object[])
                        .ToArray();
                    rowVec = new VectorValue(mv.Type, new HLSLRegister<object[]>(perThread));
                }
                else
                {
                    var rowElems = mv.Values.UniformValue.Skip(r * cols).Take(cols).ToArray();
                    rowVec = new VectorValue(mv.Type, new HLSLRegister<object[]>(rowElems));
                }
                BuildVarRows(rows, $"[{r}]", rowVec, depth + 1, $"{path}[{r}]");
            }
        }
    }

    private string FormatValue(HLSLValue value, int threadIndex)
    {
        if (value is ReferenceValue rv) value = rv.Get();
        if (value == null) return "null";

        return value switch
        {
            ScalarValue sv => FormatScalar(sv, threadIndex),
            VectorValue vv => FormatVector(vv, threadIndex),
            MatrixValue mv => FormatMatrix(mv, threadIndex),
            StructValue sv2 => FormatStruct(sv2, threadIndex),
            ArrayValue av => $"[{av.Values.Length}]",
            PredefinedObjectValue pov => pov.ToString(),
            _ => value.GetType().Name
        };
    }

    private string FormatScalar(ScalarValue sv, int threadIndex)
    {
        try
        {
            int idx = Math.Min(threadIndex, sv.ThreadCount - 1);
            object v = sv.Value.Get(idx);
            return FormatObject(v);
        }
        catch { return "?"; }
    }

    private string FormatVector(VectorValue vv, int threadIndex)
    {
        try
        {
            int idx = Math.Min(threadIndex, vv.ThreadCount - 1);
            object[] comps = vv.Values.Get(idx);
            if (comps == null) return "(null)";
            return $"({string.Join(", ", comps.Select(c => FormatObject(c)))})";
        }
        catch { return "?"; }
    }

    private string FormatMatrix(MatrixValue mv, int threadIndex)
    {
        return $"[{mv.Rows}×{mv.Columns}]";
    }

    private string FormatStruct(StructValue sv, int threadIndex)
    {
        try
        {
            var parts = sv.Members.Take(4).Select(kv => $"{kv.Key}: {FormatValue(kv.Value, threadIndex)}");
            string body = string.Join(", ", parts);
            if (sv.Members.Count > 4) body += ", ...";
            return "{" + body + "}";
        }
        catch { return "{struct}"; }
    }

    private static string FormatObject(object? v)
    {
        if (v is float f) return f.ToString("G6", CultureInfo.InvariantCulture);
        if (v is double d) return d.ToString("G6", CultureInfo.InvariantCulture);
        return Convert.ToString(v, CultureInfo.InvariantCulture) ?? "null";
    }

    [JSInvokable]
    public string? GetHoverValue(string identifier)
    {
        if (!isDebugging || debugStepIndex < 0 || debugStepIndex >= debugTrace.Count)
            return null;
        var step = debugTrace[debugStepIndex];
        // Check locals in the current (innermost) frame first
        if (step.FrameVariables.Length > 0 && step.FrameVariables[0].TryGetValue(identifier, out var localVal))
            return FormatValue(localVal, inspectedThread);
        // Fall back to globals
        if (step.GlobalVariables.TryGetValue(identifier, out var globalVal))
            return FormatValue(globalVal, inspectedThread);
        return null;
    }

    // --- Helpers shared by Run and StartDebug ---
    private HLSLParserConfig MakeParserConfig()
    {
        string? filePath = TabbedEditorConfig.Enabled && editorTabs.Count > 0
            ? editorTabs[activeTabIndex].Path
            : null;
        return new HLSLParserConfig
        {
            BasePath = filePath != null ? System.IO.Path.GetDirectoryName(filePath) ?? "" : ""
        };
    }

    private static VectorValue BuildThreadArg(int wx, int wy, int threadCount, int groupOffsetX = 0, int groupOffsetY = 0)
    {
        var threadIds = new object[threadCount][];
        for (int i = 0; i < threadCount; i++)
            threadIds[i] = new object[] {
                (float)(i % wx + groupOffsetX * wx) + 0.5f,
                (float)(i / wx + groupOffsetY * wy) + 0.5f,
                0.0f,
                1.0f
            };
        return new VectorValue(ScalarType.Float, new HLSLRegister<object[]>(threadIds).Converge());
    }

    private HLSLValue CallMain(VectorValue threadArg)
    {
        try
        {
            return runner.CallFunction(entryPoint, threadArg);
        }
        catch (Exception ex) when (ex.Message.Contains($"Unknown function '{entryPoint}' called."))
        {
            return runner.CallFunction(entryPoint);
        }
    }

    private static HLSLValue CallMainWith(HLSLRunner r, VectorValue threadArg, string entryPoint)
    {
        try
        {
            return r.CallFunction(entryPoint, threadArg);
        }
        catch (Exception ex) when (ex.Message.Contains($"Unknown function '{entryPoint}' called."))
        {
            return r.CallFunction(entryPoint);
        }
    }

    private async Task OnImmediateKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await EvaluateImmediate();
    }

    private async Task EvaluateImmediate()
    {
        string expr = immediateInput.Trim();
        if (string.IsNullOrEmpty(expr) || debugStepIndex < 0 || string.IsNullOrEmpty(debugCode)) return;
        immediateInput = "";

        int wx = Math.Max(1, warpX);
        int wy = Math.Max(1, warpY);
        int threadCount = wx * wy;

        string resultStr;
        bool isError = false;

        try
        {
            var evalRunner = new HLSLRunner(wx, wy);
            evalRunner.SetVariable("WARP_SIZE_X", new ScalarValue(ScalarType.Uint, new HLSLRegister<object>((uint)wx)));
            evalRunner.SetVariable("WARP_SIZE_Y", new ScalarValue(ScalarType.Uint, new HLSLRegister<object>((uint)wy)));

            HLSLValue evalResult = null;
            Exception evalError = null;
            int stepCount = 0;
            int targetStep = debugStepIndex;

            evalRunner.DebugHook = _ =>
            {
                if (stepCount == targetStep)
                {
                    try { evalResult = evalRunner.EvaluateExpression(expr); }
                    catch (Exception ex) { evalError = ex; }
                    throw new OperationCanceledException();
                }
                stepCount++;
            };

            var sw = new System.IO.StringWriter();
            var oldOut = Console.Out;
            Console.SetOut(sw);
            try
            {
                bool cancelledInProcessCode = false;
                try { evalRunner.ProcessCode(debugCode, MakeParserConfig()); }
                catch (OperationCanceledException) { cancelledInProcessCode = true; }
                if (!cancelledInProcessCode)
                {
                    var threadArg = BuildThreadArg(wx, wy, threadCount, groupOffsetX, groupOffsetY);
                    try { CallMainWith(evalRunner, threadArg, entryPoint); }
                    catch (OperationCanceledException) { }
                }
            }
            finally { Console.SetOut(oldOut); }

            if (evalError != null) { resultStr = evalError.Message; isError = true; }
            else if (evalResult != null) resultStr = FormatValue(evalResult, inspectedThread);
            else { resultStr = "(step not reached - expression may be after this point)"; isError = true; }
        }
        catch (Exception ex)
        {
            resultStr = ex.Message;
            isError = true;
        }

        immediateHistory.Add(new ImmediateEntry { Expression = expr, Result = resultStr, IsError = isError });
        StateHasChanged();
        await Task.Yield();
        await JS.InvokeVoidAsync("scrollImmediateToBottom");
    }

    private void TryExtractImage(HLSLValue result, int wx, int wy)
    {
        int threadCount = wx * wy;

        if (result is VectorValue vv)
        {
            int components = vv.Size;
            imageWidth = wx;
            imageHeight = wy;
            imagePixels = new byte[threadCount * 4];
            for (int i = 0; i < threadCount; i++)
            {
                var c = vv.Values.Get(i);
                imagePixels[i * 4 + 0] = FloatToByte(components > 0 ? Convert.ToSingle(c[0]) : 0f);
                imagePixels[i * 4 + 1] = FloatToByte(components > 1 ? Convert.ToSingle(c[1]) : 0f);
                imagePixels[i * 4 + 2] = FloatToByte(components > 2 ? Convert.ToSingle(c[2]) : 0f);
                imagePixels[i * 4 + 3] = FloatToByte(components > 3 ? Convert.ToSingle(c[3]) : 1f);
            }
            hasImage = true;
        }
        else if (result is ScalarValue sv && sv.Type != ScalarType.Void)
        {
            imageWidth = wx;
            imageHeight = wy;
            imagePixels = new byte[threadCount * 4];
            for (int i = 0; i < threadCount; i++)
            {
                byte gray = FloatToByte(Convert.ToSingle(sv.Value.Get(i)));
                imagePixels[i * 4 + 0] = gray;
                imagePixels[i * 4 + 1] = gray;
                imagePixels[i * 4 + 2] = gray;
                imagePixels[i * 4 + 3] = 255;
            }
            hasImage = true;
        }
    }

    private static byte FloatToByte(float v) => (byte)(Math.Clamp(v, 0f, 1f) * 255f + 0.5f);

    // --- Permalink ---
    private static string GetQueryParam(string url, string key)
    {
        var query = new Uri(url).Query.TrimStart('?');
        foreach (var part in query.Split('&'))
        {
            var kv = part.Split('=', 2);
            if (kv.Length == 2 && Uri.UnescapeDataString(kv[0]) == key)
                return Uri.UnescapeDataString(kv[1]);
        }
        return null;
    }

    private static string CompressCode(string code)
    {
        var bytes = Encoding.UTF8.GetBytes(code);
        using var output = new MemoryStream();
        using (var gz = new GZipStream(output, CompressionLevel.Optimal))
            gz.Write(bytes, 0, bytes.Length);
        return Convert.ToBase64String(output.ToArray())
            .Replace('+', '-').Replace('/', '_').TrimEnd('=');
    }

    private static string DecompressCode(string encoded)
    {
        encoded = encoded.Replace('-', '+').Replace('_', '/');
        switch (encoded.Length % 4)
        {
            case 2: encoded += "=="; break;
            case 3: encoded += "="; break;
        }
        var bytes = Convert.FromBase64String(encoded);
        using var input = new MemoryStream(bytes);
        using var gz = new GZipStream(input, CompressionMode.Decompress);
        using var output = new MemoryStream();
        gz.CopyTo(output);
        return Encoding.UTF8.GetString(output.ToArray());
    }

    private async Task CopyPermalink()
    {
        string code = await JS.InvokeAsync<string>("getMonacoValue");
        string encoded = CompressCode(code);
        string baseUrl = PermalinkBase.Url ?? new Uri(Nav.Uri).GetLeftPart(UriPartial.Path);
        string permalink = $"{baseUrl.TrimEnd('/')}/?c={encoded}";
        await JS.InvokeVoidAsync("copyToClipboard", permalink);
    }

    public async ValueTask DisposeAsync()
    {
        dotNetRef?.Dispose();
        await JS.InvokeVoidAsync("highlightDebugLine", 0);
        await JS.InvokeVoidAsync("setBreakpoints", Array.Empty<int>());
    }
